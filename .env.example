# =============================================
# Limis 实验室信息管理系统 - 环境变量配置
# =============================================
# 复制本文件为 .env 并根据实际情况修改
# cp .env.example .env

# ====================== 数据库配置 ======================
# PostgreSQL 数据库配置
DB_NAME=limis
DB_USER=limis
DB_PASSWORD=limis123
DB_HOST=db                    # Docker环境下使用 'db'，本地开发使用 'localhost'
DB_PORT=5432

# ====================== Redis 配置 ======================
# Redis 缓存和 Celery Broker
REDIS_URL=redis://redis:6379/0

# ====================== Django 配置 ======================
# Django 密钥（生产环境必须修改为安全的随机字符串）
SECRET_KEY=your-secret-key-here-change-in-production!!!

# 允许访问的主机
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.100.231

# 是否启用 HTTPS（前端有 TLS 终止时设为 true）
USE_HTTPS=false

# 调试模式（生产环境必须设为 False）
DEBUG=true

# ====================== 对象存储 (MinIO) ======================
# 文件上传存储服务
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=limis
MINIO_SECURE=false

# ====================== CORS 配置 ======================
# 前端域名列表（开发环境）
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://127.0.0.1:3000,http://192.168.100.231:3000

# ====================== 邮件配置（可选） ======================
# EMAIL_HOST=smtp.163.com
# EMAIL_PORT=465
# EMAIL_HOST_USER=your-email@163.com
# EMAIL_HOST_PASSWORD=your-password
# EMAIL_USE_SSL=true
# DEFAULT_FROM_EMAIL=实验室管理系统 <your-email@163.com>

# ====================== 其他配置 ======================
# 时区
TIME_ZONE=Asia/Shanghai

# 登录相关
LOGIN_URL=/api/v1/system/login/
LOGIN_REDIRECT_URL=/api/v1/system/me/
